# =============================================================================
# Hades Watch — Environment Template
# =============================================================================
# Copy to `.env` for local development. On production, create `.env` on the
# server only — NEVER commit real secrets or production `.env` files to git.
#
# Generate AUTH_SECRET (32+ bytes):
#   openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV="development"
# Production: NODE_ENV="production"

NEXT_PUBLIC_APP_NAME="Hades Watch"
# Production: https://hadeswatch.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js base URL — must match public site URL
# Production: https://hadeswatch.com
AUTH_URL="http://localhost:3000"

# REQUIRED — minimum 16 chars locally; use 32+ random bytes in production
# Production: generate with `openssl rand -base64 32` — never use defaults
AUTH_SECRET="replace-me-with-a-real-secret"

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local example only — use a strong unique password in production
DATABASE_URL="postgresql://archivist:your_password@localhost:5432/hadeswatch_db?schema=public"
# Remote/managed DB: add ?sslmode=require if provider requires SSL

# -----------------------------------------------------------------------------
# Email / SMTP (required before public launch)
# -----------------------------------------------------------------------------
# Without SMTP, verification/reset emails log dev links locally only.
# Production MUST configure SMTP before launch.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-smtp-user"
# SMTP_PASSWORD="your-smtp-password"
# SMTP_FROM="noreply@hadeswatch.com"

# -----------------------------------------------------------------------------
# Security / Launch
# -----------------------------------------------------------------------------
# Rate limiting (default on unless set to false)
RATE_LIMIT_ENABLED="true"

# Production: MUST be true — blocks dev invite seeding
# DISABLE_DEV_INVITES="true"

# Production: set true when ready to require verified email at login
# REQUIRE_EMAIL_VERIFICATION="true"

# Set true when behind Nginx/Cloudflare reverse proxy
# TRUSTED_PROXY_HEADERS="true"

# One-time Owner invite bootstrap (see docs/ADMIN_BOOTSTRAP.md)
# NEVER leave true after bootstrap completes
# ALLOW_PROD_ADMIN_BOOTSTRAP="true"

# Dedicated pepper for out-of-band verification HMAC (recommended in production)
# Falls back to AUTH_SECRET if unset — see docs/BETA_ACCESS_MODEL.md
# VERIFICATION_PEPPER=""

# -----------------------------------------------------------------------------
# Jitsi (convenience links — NOT private rooms)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_JITSI_BASE_URL="https://meet.jit.si"

# -----------------------------------------------------------------------------
# Production checklist (hadeswatch.com)
# -----------------------------------------------------------------------------
# [ ] AUTH_SECRET — strong random, not default
# [ ] AUTH_URL — https://hadeswatch.com
# [ ] NEXT_PUBLIC_APP_URL — https://hadeswatch.com
# [ ] DISABLE_DEV_INVITES=true
# [ ] REQUIRE_EMAIL_VERIFICATION=true (when enforcing)
# [ ] RATE_LIMIT_ENABLED=true
# [ ] TRUSTED_PROXY_HEADERS=true (behind Nginx)
# [ ] SMTP fully configured
# [ ] Run: npm run db:deploy (NOT db:migrate or db:seed)
# [ ] Revoke all DEV-* invite codes
# See: docs/LAUNCH_CHECKLIST.md

{
  "name": "hades-watch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postbuild": "bash scripts/copy-standalone-assets.sh",
    "deploy:standalone-assets": "bash scripts/copy-standalone-assets.sh",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:factions": "tsx prisma/scripts/seed-factions.ts",
    "db:seed:lore": "prisma generate && tsx prisma/scripts/seed-lore.ts",
    "db:seed:archive": "prisma generate && tsx prisma/scripts/seed-archive.ts",
    "db:seed:test-users": "tsx prisma/scripts/seed-test-users.ts",
    "db:cleanup-test-users": "tsx prisma/scripts/cleanup-test-users.ts",
    "db:bootstrap": "tsx prisma/scripts/bootstrap-owner-invite.ts",
    "db:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "media:import-track": "tsx prisma/scripts/import-media-track.ts",
    "db:verify:world-lore": "prisma generate && tsx prisma/scripts/verify-world-lore.ts",
    "db:seed:missions:first-descent": "prisma generate && tsx prisma/scripts/seed-missions-first-descent.ts",
    "deploy:verify": "bash scripts/verify-production-deploy.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

  author    User            @relation("ForumThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments  ForumComment[]
  reactions ForumReaction[] @relation("ForumThreadReactions")

  @@index([categoryId, lastActivityAt])
  @@index([authorId])
  @@index([status])

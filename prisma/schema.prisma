// Hades Watch — PostgreSQL schema (Phase 5)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  Owner
  Admin
  Moderator
  Expert
  Operative
  Gamer
  Member
  Recruit
  Guest
}

enum AnnouncementStatus {
  Draft
  Published
  Archived
}

enum TransmissionPriority {
  Low
  Normal
  High
  Critical
}

enum EventStatus {
  Draft
  Published
  Cancelled
  Archived
}

enum ModerationReportStatus {
  Open
  Reviewing
  Resolved
  Dismissed
}

enum FactionMembershipStatus {
  Pending
  Approved
  Rejected
  Left
}

enum QuestStatus {
  Draft
  Available
  Active
  Completed
  Archived
}

enum LoreStatus {
  Draft
  Published
  Archived
}

enum LoreCategory {
  CHARACTER_LORE
  WORLD_LORE
  FACTION_LORE
  MYTHOS_AND_ETHOS
  CURRENT_NEWS_AND_STATE_OF_AFFAIRS
}

enum ArchiveItemType {
  ARTICLE
  CODE_REPO
}

enum ArchiveItemStatus {
  DRAFT
  PUBLISHED
  PENDING_REVIEW
  HIDDEN
  REMOVED
}

enum CodeForge {
  GITHUB
  CODEBERG
  OTHER
}

enum DeadDropStatus {
  Draft
  Active
  Expired
  Archived
}

enum CipherStatus {
  Draft
  Active
  Archived
}

enum MissionParticipationStatus {
  Interested
  Joined
  InProgress
  Completed
  Dropped
}

enum MissionDifficulty {
  INITIATE
  FIELD
  SPECIALIST
}

enum MissionPackMissionType {
  REAL_WORLD_READINESS
  PRIVACY_LITERACY
  PREPAREDNESS
  REPAIR_AND_OPEN_SOURCE
  CREATIVE_MORALE
  EVERYDAY_ACTIVISM
  CIVIC_PARTICIPATION
  CAMPAIGN_STRATEGY
  WRITING_AND_MEDIA_LITERACY
  VISUAL_ACTIVISM
  DATA_LITERACY
  COMMUNITY_SERVICE
  ARCHIVING_AND_DOCUMENTATION_ETHICS
  NONVIOLENT_FIELD_PREPARATION
}

enum MissionSubmissionType {
  CERTIFICATION_PROOF
  CHECKLIST_AND_REFLECTION
  LINK_AND_CHECKLIST
  TEXT_LINK_OR_UPLOAD
  REDACTED_REFLECTION
  REDACTED_CIVIC_LOG
  REDACTED_PLANNING_SHEET
  TEXT_LINK_AND_SOURCE_NOTES
  ANONYMIZED_SUMMARY
  REDACTED_SERVICE_LOG
  REDACTED_ARCHIVE_PACKET
  REDACTED_SUPPORT_PLAN
}

enum MissionReviewMode {
  MANUAL
  MANUAL_OR_AUTOMATED
}

enum MissionSubmissionStatus {
  Pending
  Approved
  Rejected
}

enum BadgeVerificationStatus {
  Pending
  Verified
  Rejected
}

enum FactionPosition {
  INITIATE
  MEMBER
  SPECIALIST
  CELL_LEAD
  LIEUTENANT
  LEADER
}

enum MediaVisibility {
  PRIVATE
  APPROVED_USERS
  PUBLIC
  HIDDEN
}

enum UserAccountStatus {
  Pending
  Approved
  Rejected
}

enum NetNeighborStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum UserProfileAssetKind {
  PORTRAIT
  BANNER
  BACKGROUND
  RELIC_IMAGE
  AVATAR_BACKGROUND
}

enum AvatarPartVisibility {
  PRIVATE
  SHARED_PENDING
  SHARED_APPROVED
  SHARED_REJECTED
  HIDDEN
}

enum InviteVerificationMethod {
  SIGNAL_SAFETY_NUMBER
  SIMPLEX_CONTACT
  MATRIX_DEVICE
  SESSION_ID
  PGP_FINGERPRINT
  SSH_FINGERPRINT
  OTHER
}

enum InviteVerificationStatus {
  NOT_REQUIRED
  MATCHED
  MISMATCHED
  MISSING
  MANUAL_REVIEW
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  disabled      Boolean   @default(false)
  banned        Boolean   @default(false)
  accountStatus UserAccountStatus @default(Pending)
  approvedAt    DateTime?
  approvalSource String?
  isTestAccount Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  userRoles           UserRole[]
  themePreference     ThemePreference?
  auditLogs           AuditLog[]            @relation("AuditActor")
  createdInvites      InviteCode[]          @relation("InviteCreator")
  announcements       Announcement[]        @relation("AnnouncementAuthor")
  events              Event[]               @relation("EventCreator")
  moderationReports   ModerationReport[]    @relation("ReportAuthor")
  assignedReports     ModerationReport[]    @relation("ReportAssignee")
  reviewedReports     ModerationReport[]    @relation("ReportReviewer")
  moderationNotes     ModerationNote[]      @relation("NoteAuthor")
  notesAbout          ModerationNote[]      @relation("NoteSubject")
  character           Character?
  factionMemberships  FactionMembership[]
  loreUnlocks         UserLoreUnlock[]
  createdLore         LoreEntry[]           @relation("LoreAuthor")
  submittedArchiveItems ArchiveItem[]       @relation("ArchiveItemSubmitter")
  archiveComments     ArchiveComment[]      @relation("ArchiveCommentAuthor")
  createdDeadDrops    DeadDrop[]            @relation("DeadDropAuthor")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  missionParticipations   MissionParticipation[]
  missionSubmissions      MissionSubmission[]      @relation("MissionSubmitter")
  reviewedMissionSubmissions MissionSubmission[]   @relation("MissionReviewer")
  reviewedUserBadges      UserBadge[]              @relation("BadgeReviewer")
  cipherSolves            CipherSolve[]
  inviteRedemption        InviteRedemption?
  verificationClaim       UserVerificationClaim?
  userBadges              UserBadge[]
  spotifyPlaylistId       String?
  spotifyPlaylistUrl      String?
  spotifyEmbedUrl         String?
  activeTitle             String?
  mediaAlbumsCreated      MediaAlbum[]  @relation("MediaAlbumCreator")
  mediaTracksUploaded     MediaTrack[]  @relation("MediaTrackUploader")
  chatMessages            ChatMessage[] @relation("ChatMessageAuthor")
  chatMessagesDeleted     ChatMessage[] @relation("ChatMessageDeletedBy")
  netNeighborsSubmitted   NetNeighbor[] @relation("NetNeighborSubmittedBy")
  netNeighborsReviewed    NetNeighbor[] @relation("NetNeighborReviewedBy")
  profileCustomization    UserProfileCustomization?
  profileWorld            ProfileWorld?
  userAvatar              UserAvatar?
  profileAssets           UserProfileAsset[]
  avatarUserParts         AvatarUserPart[]
  avatarForgeAccessRequest AvatarForgeAccessRequest? @relation("AvatarForgeAccessUser")
  avatarForgeReviews      AvatarForgeAccessRequest[] @relation("AvatarForgeAccessReviewer")
  communitySubmissions         CommunitySubmission[] @relation("CommunitySubmissionAuthor")
  communitySubmissionsReviewed CommunitySubmission[] @relation("CommunitySubmissionReviewer")
  forumThreads                 ForumThread[]         @relation("ForumThreadAuthor")
  forumComments                ForumComment[]        @relation("ForumCommentAuthor")
  forumReactions               ForumReaction[]       @relation("ForumReactionAuthor")
  volunteerOpportunitiesCreated VolunteerOpportunity[] @relation("VolunteerOpportunityCreator")
  volunteerResponses           VolunteerResponse[]   @relation("VolunteerResponseAuthor")
  volunteerResponsesReviewed   VolunteerResponse[]   @relation("VolunteerResponseReviewer")
  guildsFounded                Guild[]               @relation("GuildFounder")
  guildMemberships             GuildMembership[]
  reputationEvents             ReputationEvent[]
  loreSubmissions              LoreSubmission[]      @relation("LoreSubmissionAuthor")
  loreSubmissionsReviewed      LoreSubmission[]      @relation("LoreSubmissionReviewer")
  playerRecognitionsReceived   PlayerRecognition[]   @relation("RecognitionRecipient")
  playerRecognitionsGranted    PlayerRecognition[]   @relation("RecognitionGranter")
  mmoFieldLogs                 MmoFieldLog[]
  mmoDeadDropSubmissions       MmoDeadDropSubmission[]
  mmoPlayableSubmissions       MmoPlayableSubmission[] @relation("PlayableSubmissionAuthor")
  reviewedPlayableSubmissions  MmoPlayableSubmission[] @relation("PlayableSubmissionReviewer")
  mmoLootGrants                MmoLootGrant[]
  mmoLoreUnlockGrants          MmoLoreUnlockGrant[]
  reviewedMmoDeadDropSubmissions MmoDeadDropSubmission[] @relation("MmoDeadDropReviewer")
  playerTitleGrants            PlayerTitleGrant[]
  playerTitlesGranted          PlayerTitleGrant[]      @relation("PlayerTitleGranter")
  avatarUnlockGrants           UserAvatarUnlock[]
  avatarUnlocksGranted         UserAvatarUnlock[]      @relation("AvatarUnlockGranter")
  adminRewardGrantsGiven       AdminRewardGrantAudit[] @relation("AdminRewardGranter")
  adminRewardGrantsReceived    AdminRewardGrantAudit[] @relation("AdminRewardRecipient")
  forumProfile                 ForumProfile?
  forumSignatureAssets         ForumSignatureAsset[]
  forumUserPreference          ForumUserPreference?
  notificationsReceived        UserNotification[]      @relation("NotificationRecipient")
  notificationsSent            UserNotification[]      @relation("NotificationActor")
  forumCommentsQuoted          ForumComment[]          @relation("ForumQuoteAuthor")
  @@index([createdAt])
  @@index([accountStatus])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles UserRole[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model InviteCode {
  id              String    @id @default(cuid())
  code            String    @unique
  emailRestricted String?
  roleGranted     RoleName?
  maxUses         Int       @default(1)
  usesCount       Int       @default(0)
  expiresAt       DateTime?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  revoked         Boolean   @default(false)
  isDevCode       Boolean   @default(false)
  autoApproveOnRegister Boolean @default(false)

  createdBy User? @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  redemptions InviteRedemption[]
  verificationRequirement InviteVerificationRequirement?

  @@index([revoked])
  @@index([expiresAt])
}

model InviteRedemption {
  id           String    @id @default(cuid())
  inviteCodeId String
  userId       String    @unique
  roleGranted  RoleName?
  redeemedAt   DateTime  @default(now())

  invite InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inviteCodeId])
}

model InviteVerificationRequirement {
  id                 String                   @id @default(cuid())
  inviteCodeId       String                   @unique
  method             InviteVerificationMethod
  label              String?
  expectedHash       String
  expectedPreview    String?
  autoApproveOnMatch Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  invite InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
}

model UserVerificationClaim {
  id               String                    @id @default(cuid())
  userId           String                    @unique
  inviteCodeId     String?
  method           InviteVerificationMethod?
  submittedHash    String?
  submittedPreview String?
  status           InviteVerificationStatus  @default(NOT_REQUIRED)
  reviewedAt       DateTime?
  reviewedById     String?
  createdAt        DateTime                  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([inviteCodeId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  ipHash     String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
}

model Announcement {
  id           String               @id @default(cuid())
  title        String
  body         String               @db.Text
  status       AnnouncementStatus   @default(Draft)
  priority     TransmissionPriority @default(Normal)
  pinned       Boolean              @default(false)
  audienceRole RoleName?
  authorId     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  publishedAt  DateTime?

  author User? @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([publishedAt])
}

model Event {
  id            String      @id @default(cuid())
  title         String
  description   String      @db.Text
  eventType     String      @default("general")
  status        EventStatus @default(Draft)
  startsAt      DateTime
  endsAt        DateTime?
  location      String?
  virtualUrl    String?
  jitsiRoomName String?
  audienceRole  RoleName?
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cancelledAt   DateTime?

  createdBy User? @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([startsAt])
}

model ModerationReport {
  id             String                 @id @default(cuid())
  reporterId     String?
  targetType     String
  targetId       String
  reason         String                 @db.Text
  status         ModerationReportStatus @default(Open)
  assignedToId   String?
  resolutionNote String?                @db.Text
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  reporter   User? @relation("ReportAuthor", fields: [reporterId], references: [id], onDelete: SetNull)
  assignedTo User? @relation("ReportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  reviewedBy User? @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model ModerationNote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String?
  body      String   @db.Text
  createdAt DateTime @default(now())

  subject User  @relation("NoteSubject", fields: [userId], references: [id], onDelete: Cascade)
  author  User? @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model Character {
  id         String   @id @default(cuid())
  userId     String   @unique
  callsign   String   @unique
  pronouns   String?
  bio        String?  @db.Text
  archetype  String?
  avatarUrl  String?
  isPublic   Boolean  @default(true)
  factionId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  faction Faction? @relation(fields: [factionId], references: [id], onDelete: SetNull)

  @@index([factionId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Faction {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String   @unique
  description      String?  @db.Text
  tagline          String?
  archetype        String?
  leaderName       String?
  leaderTitle      String?
  leaderLore       String?  @db.Text
  coreValues       Json?
  palette          Json?
  symbol           String?  @db.Text
  motto            String?
  rivalrySlug      String?
  synergySlug      String?
  themeUnlock      String?
  typicalMissions  Json?
  reputationFlavor String?  @db.Text
  badges           Json?
  titles           Json?
  isAlliance       Boolean  @default(false)
  allianceId       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  alliance     Faction?  @relation("FactionAlliance", fields: [allianceId], references: [id], onDelete: SetNull)
  cells        Faction[] @relation("FactionAlliance")
  characters   Character[]
  quests       Quest[]
  memberships  FactionMembership[]
  loreEntries  LoreEntry[]
  badgeRecords Badge[]
}

model FactionMembership {
  id           String                  @id @default(cuid())
  userId       String
  factionId    String
  status       FactionMembershipStatus @default(Pending)
  position     FactionPosition         @default(INITIATE)
  displayTitle String?
  reputation   Int                     @default(0)
  isPrimary    Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  faction Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)

  @@unique([userId, factionId])
  @@index([status])
}

model Badge {
  id                       String   @id @default(cuid())
  slug                     String   @unique
  name                     String
  description              String?
  factionId                String?
  color                    String?
  requirement              String?  @db.Text
  proofType                String?
  missionSlug              String?
  cipherSlug               String?
  tier                     String?
  assetPath                String?
  requiredForMissionCompletion Boolean @default(false)
  isMissionCompletionBadge Boolean  @default(false)
  placeholderText          String?
  placeholderColor         String?
  profileDisplayCategory   String?
  createdAt                DateTime @default(now())

  faction    Faction?    @relation(fields: [factionId], references: [id], onDelete: SetNull)
  userBadges UserBadge[]
}

model UserBadge {
  id                 String                  @id @default(cuid())
  userId             String
  badgeId            String
  awardedAt          DateTime                @default(now())
  awardedById        String?
  verificationStatus BadgeVerificationStatus @default(Verified)
  missionQuestId     String?
  reviewedAt         DateTime?
  reviewedById       String?
  reviewNote         String?

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  reviewer User?  @relation("BadgeReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([verificationStatus])
}

model Quest {
  id                        String                  @id @default(cuid())
  slug                      String                  @unique
  title                     String
  description               String                  @db.Text
  status                    QuestStatus             @default(Draft)
  factionId                 String?
  difficulty                MissionDifficulty?
  missionType               MissionPackMissionType?
  estimatedTime             String?
  visibility                String?                 @default("approved")
  repeatable                Boolean                 @default(false)
  openToAllFactions         Boolean                 @default(true)
  reputationReward          Int?
  completionBadgeSlug       String?
  requiredBadgeSlugs        Json?
  submissionType            MissionSubmissionType?
  reviewMode                MissionReviewMode?
  nonviolenceClassification String?
  safetyNotes               String?                 @db.Text
  proofPrivacyNotes         String?                 @db.Text
  loreUnlockSlug            String?
  missionPack               String?
  missionMetadata           Json?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  faction        Faction?               @relation(fields: [factionId], references: [id], onDelete: SetNull)
  participations MissionParticipation[]
  submissions    MissionSubmission[]

  @@index([status])
  @@index([factionId])
  @@index([missionPack])
}

model MissionParticipation {
  id          String                     @id @default(cuid())
  userId      String
  questId     String
  status      MissionParticipationStatus @default(Joined)
  joinedAt    DateTime                   @default(now())
  completedAt DateTime?
  notes       String?                    @db.Text
  updatedAt   DateTime                   @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@index([status])
  @@index([questId])
}

model MissionSubmission {
  id                String                  @id @default(cuid())
  userId            String
  questId           String
  status            MissionSubmissionStatus @default(Pending)
  proofPacket       Json?
  safetyAffirmation Boolean                 @default(false)
  submittedAt       DateTime                @default(now())
  reviewedAt        DateTime?
  reviewedById      String?
  reviewNote        String?                 @db.Text
  updatedAt         DateTime                @updatedAt

  user     User  @relation("MissionSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  quest    Quest @relation(fields: [questId], references: [id], onDelete: Cascade)
  reviewer User? @relation("MissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([questId])
  @@index([userId])
}

model LoreEntry {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  excerpt          String?
  body             String        @db.Text
  status           LoreStatus    @default(Draft)
  category         LoreCategory?
  deadIndexId      String?
  loreMetadata     Json?
  requiredRole     RoleName?
  requiredFactionId String?
  authorId         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?

  author          User?            @relation("LoreAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  requiredFaction Faction?         @relation(fields: [requiredFactionId], references: [id], onDelete: SetNull)
  unlocks         UserLoreUnlock[]

  @@index([status])
  @@index([slug])
  @@index([category])
}

model UserLoreUnlock {
  id          String   @id @default(cuid())
  userId      String
  loreEntryId String
  unlockedAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loreEntry LoreEntry @relation(fields: [loreEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, loreEntryId])
}

model ArchiveItem {
  id            String            @id @default(cuid())
  slug          String            @unique
  type          ArchiveItemType
  status        ArchiveItemStatus @default(PUBLISHED)
  title         String
  sourceName    String?
  sourceUrl     String
  domain        String?
  summary       String?           @db.Text
  tags          Json?
  forge         CodeForge?
  repoOwner     String?
  repoName      String?
  submittedById String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  submittedBy User?             @relation("ArchiveItemSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  comments    ArchiveComment[]

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([slug])
}

model ArchiveComment {
  id            String   @id @default(cuid())
  archiveItemId String
  authorId      String
  body          String   @db.Text
  parentId      String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  archiveItem ArchiveItem      @relation(fields: [archiveItemId], references: [id], onDelete: Cascade)
  author      User             @relation("ArchiveCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent      ArchiveComment?  @relation("ArchiveCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     ArchiveComment[] @relation("ArchiveCommentReplies")

  @@index([archiveItemId])
  @@index([authorId])
  @@index([parentId])
}

model DeadDrop {
  id            String         @id @default(cuid())
  slug          String         @unique
  codename      String
  title         String
  locationHint  String
  message       String         @db.Text
  status        DeadDropStatus @default(Active)
  clearanceRole RoleName?

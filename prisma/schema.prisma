  ownerRole          String?
  description        String                   @db.Text
  acceptanceCriteria String?                  @db.Text
  rewardSummary      String?                  @db.Text
  badgeHook          String?
  avatarUnlockHook   String?
  reviewRequired     Boolean                  @default(true)
  status             MmoPublicWorksTaskStatus @default(open)
  safetyNote         String?                  @db.Text
  assetNeedPath      String?
  sortOrder          Int                      @default(0)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([taskType, status])
}

model MmoRelicSet {
  id                   String   @id @default(cuid())
  title                String
  slug                 String   @unique
  fragmentsNeeded      Json     @default("[]")
  completedRelicName   String
  profileDisplayEffect String?  @db.Text
  avatarUnlockHook     String?
  badgeHook            String?
  safetyNote           String?  @db.Text
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MmoRoomStateDefinition {
  id           String   @id @default(cuid())
  stateName    String
  roomSlug     String?
  trigger      String?  @db.Text
  roomCopy     String?  @db.Text
  visualEffect String?  @db.Text
  rewardHook   String?
  safetyNote   String?  @db.Text
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([roomSlug, stateName])
  @@index([roomSlug])
}

model MmoVisitor {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  appearanceText String   @db.Text
  roomSlug       String
  prompt         String   @db.Text
  rewardSummary  String?  @db.Text
  loreUnlock     String?
  avatarItem     String?
  fieldLogText   String?
  safetyNote     String?  @db.Text
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MmoSeasonalEvent {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  seasonTiming     String?
  eventRooms       Json     @default("[]")
  eventPrompts     Json     @default("[]")
  eventRewards     String?  @db.Text
  badges           Json     @default("[]")
  profileCosmetics Json     @default("[]")
  avatarUnlocks    Json     @default("[]")
  guildHooks       String?  @db.Text
  safetyNotes      String?  @db.Text
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
